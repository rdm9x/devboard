# =============================================================================
# .gitignore — devboard
# Покрывает: Python / venv / тест-кеши / типчекеры / secrets / БД проекта /
#            Claude+MCP локальное / IDE / OS / логи / build-артефакты / аудиты.
# =============================================================================

# -----------------------------------------------------------------------------
# Python: байткод и C-расширения
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# -----------------------------------------------------------------------------
# Python: distribution / packaging
# -----------------------------------------------------------------------------
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# Virtualenvs
# -----------------------------------------------------------------------------
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# -----------------------------------------------------------------------------
# pip
# -----------------------------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Тесты и покрытие (pytest, coverage, hypothesis, tox, nose)
# -----------------------------------------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# -----------------------------------------------------------------------------
# Линтеры и type-checkers
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# -----------------------------------------------------------------------------
# Jupyter / IPython
# -----------------------------------------------------------------------------
.ipynb_checkpoints
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
# Secrets и локальные конфиги (НЕ коммитим)
# Исключение: .env.example — шаблон, его коммитим.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local

# -----------------------------------------------------------------------------
# БД и runtime-артефакты проекта devboard
# tasks.db — SQLite-канбан, не для git. Включая WAL/SHM/lock от SQLite.
# -----------------------------------------------------------------------------
tasks.db
tasks.db-shm
tasks.db-wal
tasks.db.lock
# ВАЖНО: бэкапы БД содержат историю чатов с потенциально личными данными.
# Никогда не коммитить (см. CLAUDE.md «Правило №1»).
tasks.db.bak*
data/tasks.db.bak*
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db.lock
data/*.pid
data/*.log
data/backups/
data/.env.local
data/.output_locale
data/company-context.md

# -----------------------------------------------------------------------------
# Claude Code / MCP — локальные настройки агентов
# .mcp.json (общий) — коммитим, .mcp.local.json — нет.
# -----------------------------------------------------------------------------
.claude/
.claude.json
.mcp.local.json

# -----------------------------------------------------------------------------
# IDE: JetBrains
# -----------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws

# -----------------------------------------------------------------------------
# IDE: VSCode (шаблон-пример settings.json.example при появлении коммитим)
# -----------------------------------------------------------------------------
.vscode/
!.vscode/settings.json.example

# -----------------------------------------------------------------------------
# IDE: Sublime / прочие
# -----------------------------------------------------------------------------
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS: macOS / Windows / Linux мусор
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Логи и временные файлы
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Security audit (E1.4): артефакты аудита секретов — gitignored
# -----------------------------------------------------------------------------
docs/security-audit/

# -----------------------------------------------------------------------------
# Прочее: бэкапы редакторов
# -----------------------------------------------------------------------------
*.bak
*.orig
*.rej

# -----------------------------------------------------------------------------
# Внутренние handoff-документы и черновики (не для публичного репо)
# -----------------------------------------------------------------------------
КОНЦЕПТ.md
НАЧНИ_ЗДЕСЬ.md
ПЕРЕДАЧА_СЕССИИ.md
ПРОМТ_ДЛЯ_КОЛЛЕГИ.md
ПРОМТ_РЕАЛИЗАТОРУ.md
детали_дашборда.md

# Отдельный проект (вынесем в свой репозиторий)
calculator.html

# Внутренние рекламные планы / стратегия маркетинга — НЕ публиковать
MARKETING_PLAN*.md

# =============================================================================
# Workspace: артефакты задач (не для git)
# Структура: workspace/PRJ-NNN-<slug>/<dept>/<task_id>/<file>
# Полностью игнорируем содержимое; .gitkeep сохраняет саму папку workspace/.
# =============================================================================
/workspace/**/*
!/workspace/
!/workspace/.gitkeep

# Stray test artifacts
.devboard.tasks.db
.devboard.tasks.db.lock
