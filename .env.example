# =============================================================================
# devboard — пример .env (скопируй в .env и заполни).
# .env is gitignored; .env.example коммитится как шаблон.
#
# Минимум для запуска: ANTHROPIC_API_KEY (или OPENAI_API_KEY, или OLLAMA_URL).
# Остальное опционально — значения по умолчанию указаны в комментариях.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM провайдеры (нужен минимум один — см. llm/factory.py).
# Порядок autodetect: Anthropic → OpenAI → Ollama.
# -----------------------------------------------------------------------------

# required (или OPENAI_API_KEY / OLLAMA_URL) — токен Anthropic Claude.
# Получить: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# optional — токен OpenAI, fallback если нет Anthropic.
OPENAI_API_KEY=

# optional — URL локального Ollama (default коммент в DEPLOYMENT.md).
# Внутри Docker для Ollama на хосте используй http://host.docker.internal:11434
OLLAMA_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Telegram-уведомления (tool notify_user в MCP-сервере).
# Без них notify_user молча пропускается — приложение работает.
# -----------------------------------------------------------------------------

# optional — bot-token из @BotFather.
TELEGRAM_BOT_TOKEN=

# optional — числовой chat_id получателя.
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Dashboard (Flask, дашборд/app.py).
# -----------------------------------------------------------------------------

# optional — bind-адрес внутри контейнера. Должен быть 0.0.0.0 чтобы
# Docker-проброс порта работал (default в Dockerfile: 0.0.0.0).
DEVBOARD_DASHBOARD_HOST=0.0.0.0

# optional — порт Flask внутри контейнера. Default: 4999.
DEVBOARD_DASHBOARD_PORT=4999

# optional — уровень логов дашборда (DEBUG / INFO / WARNING / ERROR).
DEVBOARD_DASHBOARD_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# MCP-сервер devboard_tasks (SQLite-канбан).
# -----------------------------------------------------------------------------

# optional — путь к БД внутри контейнера. Default: /app/data/tasks.db
# (привязан к volume ./data:/app/data в docker-compose.yml).
DEVBOARD_TASKS_DB=/app/data/tasks.db

# optional — уровень логов MCP-сервера.
DEVBOARD_TASKS_LOG_LEVEL=INFO
