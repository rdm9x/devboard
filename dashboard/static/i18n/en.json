      "finish": "Done",
      "step1": {
        "title": "Hi! Meet your AI team",
        "body": "Seven roles — team-lead, backend, frontend, QA, architect, DevOps, tech-writer — collaborate on tasks as a single team. A quick minute to show you how it works."
      },
      "step2": {
        "title": "Create tasks here",
        "body": "Click «+ New task», describe what needs doing. The team-lead will break it down and delegate."
      },
      "step3": {
        "title": "Roles live in roles/*.md",
        "body": "Each role has its own system prompt under roles/. Want to tweak behaviour? Edit that role's markdown file."
      },
      "step4": {
        "title": "Launch the team-lead — they'll dispatch work",
        "body": "«▶ Start team» — the team-lead reads the board, picks the next task and starts delegating. «⏹ Stop» ends the session."
      },
      "step5": {
        "title": "The board updates in real time",
        "body": "The «In progress» column lights up as soon as the team picks up work. No refresh needed. You're set!"
      }
    }
  },
